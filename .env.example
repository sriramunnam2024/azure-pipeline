# Copy to .env locally (gitignored). Used by scripts and local tooling only.

# Azure Storage (landing) — names only, no keys in repo
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_RESOURCE_GROUP=
AZURE_STORAGE_CONTAINER=lake
AZURE_BLOB_PREFIX=landing/

# Databricks (workspace URL, no PAT in repo — use CLI profile or env at runtime)
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
